// prisma/schema.prisma 파일 내용 (최종)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql" // url 라인은 제거되었습니다.
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Post {
  id        Int      @id @default(autoincrement())
  title     String   @db.VarChar(255)
  content   String?
  createdAt DateTime @default(now())
}
